# Local dev (default)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Production (Farcaster / Base manifest asset URLs)
# NEXT_PUBLIC_SITE_URL=https://unibase-iota.vercel.app

# Contract deploy (Foundry)
# PRIVATE_KEY=0x...                      # deployer wallet (needs ETH on Base)
# BADGE_RANK_SIGNER_PRIVATE_KEY=0x...    # rank badge signer; also used as RANK_SIGNER if unset
# RANK_SIGNER=0x...                      # optional override for BadgeNFT constructor
# BASE_RPC_URL=https://mainnet.base.org
# BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# Optional: Hub deploy block (speeds up leaderboard indexing)
# HUB_DEPLOY_FROM_BLOCK=12345678
